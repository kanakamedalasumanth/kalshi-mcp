# ============================================
# Kalshi MCP Server — Environment Configuration
# ============================================
# Copy this file to .env and fill in your credentials.

# Your Kalshi API Key ID (from kalshi.com → Account → API Keys)
KALSHI_API_KEY_ID=your-api-key-id-here

# Absolute path to your RSA private key PEM file
KALSHI_PRIVATE_KEY_PATH=/path/to/your/kalshi-private-key.pem

# API Base URL (defaults to production)
# For demo/testing: https://demo-api.kalshi.co/trade-api/v2
# For production:   https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Log level: debug | info | warn | error (defaults to info)
LOG_LEVEL=info
